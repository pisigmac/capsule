# Capsule Configuration
CAPSULE_DATABASE_URL=sqlite:///capsule.db
CAPSULES_DIR=./capsules
CAPSULES_SHARED_DIR=./capsules/shared
CAPSULES_ARCHIVED_DIR=./capsules/archived

# API Settings
API_HOST=0.0.0.0
API_PORT=9000
CAPSULE_API_URL=http://localhost:9000/api/v1

# Search
SEARCH_LIMIT=50

# Sync
SYNC_INTERVAL=30
AUTO_ARCHIVE_DAYS=90

# Development
DEBUG=false
LOG_LEVEL=INFO
